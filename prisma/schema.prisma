generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @db.Uuid
  email     String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("profiles")
}

model Event {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  description     String?
  venueName       String   @map("venue_name")
  venueAddress    String?  @map("venue_address")
  city            String
  state           String
  latitude        Float?
  longitude       Float?
  eventDate       DateTime @map("event_date")
  eventTime       String?  @map("event_time")
  flyerUrl        String?  @map("flyer_url")
  ticketUrl       String?  @map("ticket_url")
  ticketPriceInfo String?  @map("ticket_price_info")
  setlistFmUrl    String?  @map("setlist_fm_url")
  status          String   @default("pending")
  submittedBy     String?  @map("submitted_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  submitter Profile?    @relation(fields: [submittedBy], references: [id])
  bands     EventBand[]

  @@index([eventDate])
  @@index([state, city])
  @@index([status])
  @@map("events")
}

model EventBand {
  id          String  @id @default(uuid()) @db.Uuid
  eventId     String  @map("event_id") @db.Uuid
  bandName    String  @map("band_name")
  isHeadliner Boolean @default(false) @map("is_headliner")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_bands")
}
