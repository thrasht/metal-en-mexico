generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @db.Uuid
  email     String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]
  orders Order[]

  @@map("profiles")
}

model Band {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  genre     String?
  origin    String?
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  shows Show[]

  @@map("bands")
}

model Event {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  slug            String    @unique
  description     String?
  eventType       String    @default("concert") @map("event_type")
  venueName       String    @map("venue_name")
  venueAddress    String?   @map("venue_address")
  city            String
  state           String
  latitude        Float?
  longitude       Float?
  startDate       DateTime  @map("start_date")
  endDate         DateTime? @map("end_date")
  flyerUrl        String?   @map("flyer_url")
  ticketUrl       String?   @map("ticket_url")
  ticketPriceInfo String?   @map("ticket_price_info")
  status          String    @default("pending")
  submittedBy     String?   @map("submitted_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  submitter   Profile?    @relation(fields: [submittedBy], references: [id])
  shows       Show[]
  ticketTypes TicketType[]
  orders      Order[]

  @@index([startDate])
  @@index([state, city])
  @@index([status])
  @@map("events")
}

model Show {
  id           String    @id @default(uuid()) @db.Uuid
  eventId      String    @map("event_id") @db.Uuid
  bandId       String    @map("band_id") @db.Uuid
  isHeadliner  Boolean   @default(false) @map("is_headliner")
  stage        String?
  showDate     DateTime? @map("show_date")
  startTime    String?   @map("start_time")
  endTime      String?   @map("end_time")
  setlistFmUrl String?   @map("setlist_fm_url")
  sortOrder    Int       @default(0) @map("sort_order")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  band  Band  @relation(fields: [bandId], references: [id])

  @@index([eventId])
  @@index([bandId])
  @@map("shows")
}

model TicketType {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  name        String
  description String?
  price       Int                                       // Centavos MXN (35000 = $350.00)
  quantity    Int                                       // Inventario total
  sold        Int      @default(0)                      // Vendidos
  maxPerOrder Int      @default(5) @map("max_per_order")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([eventId])
  @@map("ticket_types")
}

model Order {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  status         String   @default("pending")           // pending | paid | expired | refunded
  totalAmount    Int      @map("total_amount")          // Centavos MXN
  conektaOrderId String?  @unique @map("conekta_order_id")
  customerEmail  String   @map("customer_email")
  customerName   String?  @map("customer_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user  Profile     @relation(fields: [userId], references: [id])
  event Event       @relation(fields: [eventId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           String @id @default(uuid()) @db.Uuid
  orderId      String @map("order_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid
  quantity     Int
  unitPrice    Int    @map("unit_price")                // Precio al momento de compra

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([orderId])
  @@map("order_items")
}
