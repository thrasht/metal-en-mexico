generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @db.Uuid
  email     String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("profiles")
}

model Band {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  genre     String?
  origin    String?
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  shows Show[]

  @@map("bands")
}

model Event {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  slug            String    @unique
  description     String?
  eventType       String    @default("concert") @map("event_type")
  venueName       String    @map("venue_name")
  venueAddress    String?   @map("venue_address")
  city            String
  state           String
  latitude        Float?
  longitude       Float?
  startDate       DateTime  @map("start_date")
  endDate         DateTime? @map("end_date")
  flyerUrl        String?   @map("flyer_url")
  ticketUrl       String?   @map("ticket_url")
  ticketPriceInfo String?   @map("ticket_price_info")
  status          String    @default("pending")
  submittedBy     String?   @map("submitted_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  submitter Profile? @relation(fields: [submittedBy], references: [id])
  shows     Show[]

  @@index([startDate])
  @@index([state, city])
  @@index([status])
  @@map("events")
}

model Show {
  id           String    @id @default(uuid()) @db.Uuid
  eventId      String    @map("event_id") @db.Uuid
  bandId       String    @map("band_id") @db.Uuid
  isHeadliner  Boolean   @default(false) @map("is_headliner")
  stage        String?
  showDate     DateTime? @map("show_date")
  startTime    String?   @map("start_time")
  endTime      String?   @map("end_time")
  setlistFmUrl String?   @map("setlist_fm_url")
  sortOrder    Int       @default(0) @map("sort_order")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  band  Band  @relation(fields: [bandId], references: [id])

  @@index([eventId])
  @@index([bandId])
  @@map("shows")
}
